---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const cleanPathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const cleanHref = String(href).replace(import.meta.env.BASE_URL, '');

const formatPath = (p: string) => '/' + p.replace(/^\/|\/$/g, '');

const normPathname = formatPath(cleanPathname);
const normHref = formatPath(cleanHref);

const subpath = normPathname.split('/').filter(Boolean);
const isActive = normHref === normPathname || normHref === '/' + (subpath[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
